# ── Core ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PUBLIC_WEB_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:3000

# ── Database (pgvector-enabled Postgres) ───────────────────────────────────
DATABASE_URL=postgres://laqta:laqta@localhost:5432/laqta

# ── Redis (BullMQ + cache + rate limiting) ─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth (Better Auth + Google) ────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-in-production-min-32-chars-long
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Cloudflare R2 (S3-compatible object storage) ───────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=laqta
R2_ENDPOINT=
# Public CDN base for serving renditions (Cloudflare-fronted)
R2_PUBLIC_BASE_URL=http://localhost:9000/laqta

# ── OpenRouter (ALL AI: moderation, captions, embeddings) ──────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL_MODERATION=google/gemini-2.5-flash
OPENROUTER_MODEL_CAPTION=google/gemini-2.5-flash
OPENROUTER_MODEL_EMBEDDING=openai/clip

# ── Typesense (search) ─────────────────────────────────────────────────────
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=laqta-dev-typesense-key

# ── Cloudflare Turnstile (original-download gate) ──────────────────────────
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
